{
  "name": "@nexus/component-forge",
  "version": "3.1.0",
  "description": "Starter component generation and validation utilities for Nexus Design AGI.",
  "keywords": [
    "component-generation",
    "react",
    "vue",
    "svelte"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "@nexus/design-tokens": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  }
}