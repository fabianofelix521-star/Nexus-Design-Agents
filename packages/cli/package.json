{
  "name": "@nexus/cli",
  "version": "3.1.0",
  "description": "CLI for generating Nexus Design AGI bundles, tokens, and starter surfaces.",
  "homepage": "https://github.com/fabianofelix521-star/Nexus-Design-Agents/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/fabianofelix521-star/Nexus-Design-Agents/issues"
  },
  "keywords": [
    "cli",
    "design-agents",
    "vscode",
    "codegen"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/fabianofelix521-star/Nexus-Design-Agents.git",
    "directory": "packages/cli"
  },
  "bin": {
    "nexus": "dist/index.js"
  },
  "dependencies": {
    "@nexus/component-forge": "workspace:*",
    "@nexus/core": "workspace:*",
    "@nexus/design-tokens": "workspace:*"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  }
}