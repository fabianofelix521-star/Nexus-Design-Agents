{
  "name": "nexus-design-agi",
  "version": "3.1.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/fabianofelix521-star/Nexus-Design-Agents",
  "bugs": {
    "url": "https://github.com/fabianofelix521-star/Nexus-Design-Agents/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fabianofelix521-star/Nexus-Design-Agents.git"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "changeset": "changeset",
    "clean": "pnpm -r --if-present clean",
    "demo:hermes": "pnpm build && node examples/04-hermes-runtime-demo/run-demo.mjs",
    "demo:openclaw": "pnpm build && node examples/03-openclaw-runtime-demo/run-demo.mjs",
    "demo:vscode": "pnpm build && node examples/02-vscode-webview-demo/run-demo.mjs",
    "lint": "pnpm exec biome check .",
    "release:publish": "changeset publish",
    "test": "vitest run",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.6.0",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4",
    "vitest": "^2.1.4"
  }
}