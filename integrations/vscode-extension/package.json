{
  "name": "nexus-vscode-extension",
  "version": "0.1.0",
  "publisher": "felix",
  "type": "module",
  "displayName": "Nexus Design AGI",
  "description": "Portable multi-agent design runtime for VS Code with bundle generation, surface export, and brief review commands.",
  "preview": true,
  "homepage": "https://github.com/fabianofelix521-star/Nexus-Design-Agents/tree/main/integrations/vscode-extension",
  "bugs": {
    "url": "https://github.com/fabianofelix521-star/Nexus-Design-Agents/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fabianofelix521-star/Nexus-Design-Agents.git",
    "directory": "integrations/vscode-extension"
  },
  "main": "./dist/extension.cjs",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "design",
    "agents",
    "multi-agent",
    "code-generation",
    "vscode"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "nexus.generateBundle",
        "title": "Nexus: Generate Instruction Bundle"
      },
      {
        "command": "nexus.exportSurface",
        "title": "Nexus: Export Starter Surface"
      },
      {
        "command": "nexus.reviewBrief",
        "title": "Nexus: Review Brief"
      }
    ]
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "package:vsix": "node ./scripts/release.mjs package",
    "publish:vsix": "node ./scripts/release.mjs publish",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.25.10"
  }
}